PORT=3000
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account-key.json
JWT_SECRET=your-jwt-secret
TIMEZONE=Asia/Kolkata
MANIFEST_CUTOFF_HOUR=21
MANIFEST_CRON_HOUR=23

# Comma-separated allowed CORS origins (leave empty to allow all — dev only)
ALLOWED_ORIGINS=https://your-frontend.netlify.app,https://your-custom-domain.com

# Gmail alerts (optional — email notifications are skipped if not set).
# GMAIL_APP_PASSWORD is a Google "App Password" (needs 2-Step Verification on
# the account), NOT the normal Gmail password. Toggle recipients & on/off from
# the admin panel's Email Alerts page.
GMAIL_USER=your-alerts@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Redis (optional — rate limiting and caching are disabled if not set)
# Local:      redis://localhost:6379
# Redis Cloud: redis://:password@host:port
REDIS_URL=redis://localhost:6379
